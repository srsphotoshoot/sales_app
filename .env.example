# Sales SRS - API Configuration Example
# Copy this file to .env to use a live API

# The URL of your backend API that returns the product JSON
VITE_API_URL=https://your-api-endpoint.com/api/products

# Optional: Add any other environment-specific variables here
# VITE_API_KEY=your_secret_key

# Company name shown in generated PDFs (default: SHREE RADHA STUDIO)
# VITE_COMPANY_NAME=Your Company Name

# Admin master PIN (default: 1234 — change this!)
# VITE_ADMIN_MASTER_PIN=your_secure_pin
