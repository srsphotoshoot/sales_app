# Sales SRS - API Configuration Example
# Copy this file to .env to use a live API

# The URL of your backend API that returns the product JSON
VITE_API_URL=https://your-api-endpoint.com/api/products

# Optional: Add any other environment-specific variables here
# VITE_API_KEY=your_secret_key

# Company name shown in generated PDFs (default: SHREE RADHA STUDIO)
# VITE_COMPANY_NAME=Your Company Name

# Admin master PIN (default: 1234 — change this!)
# VITE_ADMIN_MASTER_PIN=your_secure_pin

# --- Google Sign-In + Drive image delivery ---
# Secret used to sign/verify app JWTs — generate a long random string, keep it secret.
JWT_SECRET=

# OAuth 2.0 Web Client ID from Google Cloud Console (used to validate login tokens server-side)
GOOGLE_CLIENT_ID=

# Same Client ID, exposed to the frontend build (Vite only inlines VITE_-prefixed vars)
VITE_GOOGLE_CLIENT_ID=

# Google Drive folder ID that product images live in — shared with each user's
# email on creation, and where new product images get uploaded to.
SALES_APP_DRIVE_FOLDER_ID=

# Break-glass fallback to the old shared-PIN/staff-code login during cutover.
# Leave unset/false once Google Sign-In is verified working in production.
ENABLE_LEGACY_PIN=false
